<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>AI Robot Sistemi</title>
<style>
  body { background: #000; color: #fff; font-family: sans-serif; margin: 0; overflow: hidden; height: 100vh; width: 100vw; }
  
  /* EKRAN YÖNETİMİ */
  .screen { display: none; flex-direction: column; align-items: center; justify-content: center; width: 100%; height: 100%; }
  #manual-screen { display: flex; } /* İlk açılışta burası görünür */
  
  /* --- MANUEL KONTROL EKRANI STİLLERİ --- */
  .panel-title { color: #0f0; margin-bottom: 20px; text-shadow: 0 0 10px #0f0; }
  .api-input { padding: 12px; width: 80%; max-width: 300px; margin-bottom: 10px; border: 2px solid #0ff; border-radius: 8px; background: #111; color: #fff; text-align: center; font-size: 16px; }
  .test-group { display: flex; gap: 10px; margin-top: 10px; margin-bottom: 20px; width: 80%; max-width: 300px; }
  .test-btn { flex: 1; padding: 10px; background: #222; border: 1px solid #aaa; color: #aaa; border-radius: 5px; cursor: pointer; }
  .test-btn.active { background: #0f0; color: #000; border-color: #0f0; }
  
  .controls { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; width: 80%; max-width: 300px; margin-bottom: 20px; }
  .ctrl-btn { padding: 15px; font-size: 14px; background: #222; color: #0f0; border: 2px solid #0f0; border-radius:8px; cursor: pointer; }
  .ctrl-btn:active { background: #0f0; color: #000; }
  
  .start-ai-btn { padding: 15px 30px; font-size: 16px; background: #0ff; color: #000; border: none; border-radius: 25px; font-weight: bold; cursor: pointer; box-shadow: 0 0 15px #0ff; margin-top: 10px; }
  #manual-status { color: #aaa; font-size: 12px; margin-top: 10px; min-height: 20px; text-align: center; }

  /* --- YAPAY ZEKA (AI) EKRANI STİLLERİ --- */
  #ai-screen { cursor: pointer; } 
  .eyes { display: flex; gap: 50px; pointer-events: none; }
  .eye { width: 90px; height: 120px; background: #0ff; border-radius: 50%; box-shadow: 0 0 40px #0ff; transition: all 0.3s; display: flex; align-items: center; justify-content: center; font-size: 60px; }
  .wink { transform: scaleY(0.1) !important; }
  .emoji-mode { background: transparent !important; box-shadow: none !important; border-radius: 0; filter: drop-shadow(0 0 20px #0ff); }
  .talking { animation: talkBlink 0.3s infinite alternate; }
  @keyframes talkBlink { 0% { transform: scaleY(1); } 100% { transform: scaleY(0.7); background: #fff; } }
  
  #ai-status { position: absolute; bottom: 30px; color: #555; font-size: 14px; pointer-events: none; text-align: center; width: 90%; }
  video { display: none; } 
</style>
</head>
<body>

<div id="manual-screen" class="screen">
    <h2 class="panel-title">MÜHENDİSLİK PANELİ</h2>
    
    <input type="text" id="tankIp" class="api-input" placeholder="Robot IP (Örn: 172.20.10.2)">
    
    <input type="password" id="apiKey" class="api-input" placeholder="Gemini API Anahtarını Gir">
    
    <div class="test-group">
        <button class="test-btn" id="camTestBtn" onclick="testCamera()">Kamera Test</button>
        <button class="test-btn" id="micTestBtn" onclick="testMic()">Mikrofon Test</button>
    </div>
    
    <div class="controls">
        <button class="ctrl-btn" onclick="sendCommand('left')">SOL</button>
        <button class="ctrl-btn" onclick="sendCommand('forward')">İLERİ</button>
        <button class="ctrl-btn" onclick="sendCommand('right')">SAĞ</button>
        <button class="ctrl-btn" style="grid-column: 1 / span 3; background:#500; color:#fff; border-color:#f00;" onclick="sendCommand('stop')">DUR</button>
        <button class="ctrl-btn" style="grid-column: 1 / span 3;" onclick="sendCommand('backward')">GERİ</button>
    </div>
    
    <button class="start-ai-btn" onclick="switchToAI()">YAPAY ZEKA MODUNA GEÇ</button>
    <div id="manual-status">Sistem hazır. IP ve API girerek başlayın.</div>
</div>

<div id="ai-screen" class="screen" onclick="toggleListening()">
    <div class="eyes">
        <div class="eye" id="leftEye"></div>
        <div class="eye" id="rightEye"></div>
    </div>
    <div id="ai-status">Dokun ve konuşmaya başla...</div>
</div>

<video id="webcam" autoplay playsinline></video>

<script>
  // --- ORTAK DEĞİŞKENLER ---
  const leftEye = document.getElementById('leftEye');
  const rightEye = document.getElementById('rightEye');
  const aiStatus = document.getElementById('ai-status');
  const manualStatus = document.getElementById('manual-status');
  const video = document.getElementById('webcam');
  
  let isMicActive = false;
  let isBotSpeaking = false;
  let chatHistory = [];
  let cameraStream = null;
  const canvas = document.createElement('canvas');

  // --- ESP32 İLETİŞİMİ (Artık IP'yi Kutudan Alıyor) ---
  function sendCommand(cmd) {
    let ip = document.getElementById('tankIp').value.trim();
    
    if (!ip) {
        manualStatus.innerText = "Hata: Önce Robotun IP Adresini girin!";
        return;
    }
    
    // Kullanıcı http:// yazmayı unutursa otomatik ekle
    if (!ip.startsWith('http://')) {
        ip = 'http://' + ip;
    }

    fetch(`${ip}/${cmd}`, { mode: 'no-cors' }).catch(() => {});
    manualStatus.innerText = "Komut gönderildi: " + cmd;
  }

  // --- DONANIM TEST FONKSİYONLARI ---
  async function testCamera() {
    try {
      if(!cameraStream) {
        cameraStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "environment" } });
        video.srcObject = cameraStream;
      }
      document.getElementById('camTestBtn').classList.add('active');
      manualStatus.innerText = "Kamera başarıyla açıldı.";
    } catch (e) { manualStatus.innerText = "Kamera hatası!"; }
  }

  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  const recognition = new SpeechRecognition();
  recognition.lang = 'tr-TR';

  function testMic() {
    try {
      recognition.start();
      document.getElementById('micTestBtn').classList.add('active');
      manualStatus.innerText = "Mikrofon dinliyor... Bir şey söyleyin.";
      recognition.onresult = (e) => {
        manualStatus.innerText = "Test Başarılı. Duyulan: " + e.results[0][0].transcript;
        recognition.stop();
      };
    } catch(e) {}
  }

  // --- MOD GEÇİŞİ (Mühendislik -> AI) ---
  async function switchToAI() {
    const userIp = document.getElementById('tankIp').value.trim();
    const userKey = document.getElementById('apiKey').value.trim();
    
    if (!userIp) {
        manualStatus.innerText = "Lütfen Robotun IP Adresini girin!";
        return;
    }
    if (!userKey) {
        manualStatus.innerText = "Lütfen API Anahtarını girin!";
        return;
    }
    
    // Kamerayı arka planda hazırla
    if(!cameraStream) await testCamera();
    
    // Ekranları Değiştir
    document.getElementById('manual-screen').style.display = 'none';
    document.getElementById('ai-screen').style.display = 'flex';
    
    // Asıl AI konuşma tanıma olaylarını (event) tanımla
    setupAILogic();
  }

  // --- AI MODU MANTIK VE İŞLEYİŞİ ---
  function setupAILogic() {
    recognition.onresult = async (event) => {
      const userText = event.results[0][0].transcript;
      aiStatus.innerText = "Düşünüyor...";
      await askGemini(userText);
    };
    
    recognition.onend = () => { 
      if (isMicActive && !isBotSpeaking) setTimeout(()=>recognition.start(), 300); 
    };
  }

  // Ekrana tıklandığında mikrofonu aç/kapat
  function toggleListening() {
    isMicActive = !isMicActive;
    
    // iOS için ilk dokunuşta ses motorunu uyandır
    if ('speechSynthesis' in window) { window.speechSynthesis.speak(new SpeechSynthesisUtterance('')); }

    if (isMicActive) {
      aiStatus.innerText = "Dinliyor...";
      aiStatus.style.color = "#0f0"; // Dinlerken yeşil yazı
      try { recognition.start(); } catch(e){}
    } else {
      aiStatus.innerText = "Dokun ve konuşmaya başla...";
      aiStatus.style.color = "#555";
      recognition.stop();
    }
  }

  function captureFrame() {
    if (!video.videoWidth) return null;
    canvas.width = video.videoWidth; canvas.height = video.videoHeight;
    canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);
    return canvas.toDataURL('image/jpeg', 0.8).split(',')[1];
  }

  async function askGemini(text) {
    const activeKey = document.getElementById('apiKey').value.trim();
    try {
      const base64Image = captureFrame();
      const currentTurnParts = [{ text: text }];
      if (base64Image) currentTurnParts.push({ inlineData: { data: base64Image, mimeType: "image/jpeg" } });

      const payloadHistory = chatHistory.map(turn => ({ role: turn.role, parts: turn.parts.filter(p => p.text) }));
      payloadHistory.push({ role: "user", parts: currentTurnParts });

      const promptContext = "Sen Gemini'sin ve fiziksel bir tank robotun beynisin. Kameradan ortamı görebilirsin. Kısa ve doğal cevap ver. Cevabının SONUNA gözleri yönetmek için [LEFT:değer][RIGHT:değer] ekle (NORMAL, WINK, EMOJİ). TANKI SÜRMEK İSTERSEN cevabının sonuna [ACTION:forward], [ACTION:backward], [ACTION:left], [ACTION:right] veya [ACTION:stop] komutu ekle.";

      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${activeKey}`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ systemInstruction: { parts: [{ text: promptContext }] }, contents: payloadHistory })
      });
      
      const data = await response.json();
      if (data.error) { aiStatus.innerText = "Hata: " + data.error.message; return; }
      
      const botText = data.candidates[0].content.parts[0].text;
      
      chatHistory.push({ role: "user", parts: [{ text: text }] });
      chatHistory.push({ role: "model", parts: [{ text: botText }] });

      // Motor komutunu ayıkla ve fonksiyona gönder
      const actionMatch = botText.match(/\[ACTION:(.*?)\]/);
      if (actionMatch) sendCommand(actionMatch[1].trim());

      executeDynamicVisuals(botText);
      speakText(botText);
    } catch (e) { aiStatus.innerText = "Bağlantı hatası."; }
  }

  function applyEyeState(eye, value) {
    eye.className = 'eye'; eye.innerText = '';
    if (value === 'WINK') { eye.classList.add('wink'); setTimeout(() => eye.classList.remove('wink'), 1000); } 
    else if (value !== 'NORMAL') { eye.classList.add('emoji-mode'); eye.innerText = value; }
  }

  function executeDynamicVisuals(text) {
    const match = text.match(/\[LEFT:(.*?)\]\[RIGHT:(.*?)\]/);
    if (match) { applyEyeState(leftEye, match[1].trim()); applyEyeState(rightEye, match[2].trim()); } 
    else { applyEyeState(leftEye, 'NORMAL'); applyEyeState(rightEye, 'NORMAL'); }
  }

  function speakText(text) {
    const cleanText = text.replace(/\[LEFT:.*?\]\[RIGHT:.*?\]/g, '').replace(/\[ACTION:.*?\]/g, '').trim();
    aiStatus.innerText = "Konuşuyor...";
    
    isBotSpeaking = true; recognition.stop(); window.speechSynthesis.cancel(); 
    const utterance = new SpeechSynthesisUtterance(cleanText);
    utterance.lang = 'tr-TR';
    
    utterance.onstart = () => {
      if (leftEye.innerText === '' && !leftEye.classList.contains('wink')) leftEye.classList.add('talking');
      if (rightEye.innerText === '' && !rightEye.classList.contains('wink')) rightEye.classList.add('talking');
    };
    utterance.onend = () => {
      isBotSpeaking = false; 
      leftEye.classList.remove('talking'); rightEye.classList.remove('talking');
      applyEyeState(leftEye, 'NORMAL'); applyEyeState(rightEye, 'NORMAL');
      
      if (isMicActive) {
        aiStatus.innerText = "Dinliyor...";
        setTimeout(()=>recognition.start(), 300);
      } else {
        aiStatus.innerText = "Dokun ve konuşmaya başla...";
      }
    };
    window.speechSynthesis.speak(utterance);
  }
</script>
</body>
</html>
